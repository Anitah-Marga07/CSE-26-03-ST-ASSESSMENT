doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Videx - Upload Video
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css' rel='stylesheet')
  link(rel='stylesheet' href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css')
  link(href='/css/upload.css' rel='stylesheet')
a.btn-back(href='/videos')
  i.bi.bi-arrow-left
.container.form-container
  h2.mb-4 Upload your video
  if success_msg && success_msg.length > 0
    .alert.alert-success.alert-dismissible.fade.show.text-center.py-2.mb-4(role='alert' style='background-color: #00B050; color: #ffffff; border: none; border-radius: 4px; font-weight: 500;')
      | #{success_msg}
      button.btn-close.btn-close-white.py-2(type='button' data-bs-dismiss='alert' aria-label='Close' style='font-size: 0.75rem;')
  if error_msg && error_msg.length > 0
    .alert.alert-danger.alert-dismissible.fade.show.text-center.py-2.mb-4(role='alert' style='background-color: #FF0000; color: #ffffff; border: none; border-radius: 4px; font-weight: 500;')
      | #{error_msg}
      button.btn-close.btn-close-white.py-2(type='button' data-bs-dismiss='alert' aria-label='Close' style='font-size: 0.75rem;')
  form#uploadForm(action='/upload' method='POST' enctype='multipart/form-data' novalidate)
    .row
      .col-md-6
        input.form-control.mb-3(type='text' placeholder='Video Title' name='title')
        .invalid-feedback Required field.
        textarea.form-control.mb-3(rows='6' placeholder='Description (Optional)' name='description')
        .invalid-feedback Required field.
        select.form-select.mb-3(name='quality')
          option(value='') Video quality
          option(value='1080p') 1080p
          option(value='720p') 720p
          option(value='480p') 480p
          option(value='360p') 360p
        .invalid-feedback Required field.
        input.form-control.mb-3(type='date' placeholder='Date of Publishing' name='publishingDate')
      .col-md-6
        .mb-3
          label.upload-label
            input(type='file' name='video' accept='video/*')
            .upload-box
              i.bi.bi-cloud-arrow-up.upload-icon-size
              p.m-0 Upload video
          .invalid-feedback Required field.
        .mb-3
          label.upload-label
            input(type='file' name='thumbnail' accept='image/*')
            .upload-box.thumbnail-box
              i.bi.bi-cloud-arrow-up.upload-icon-size
              p.m-0 Upload Thumbnail
          button.btn.btn-upload(type='submit') UPLOAD
script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js')
script.
  document.getElementById('uploadForm').addEventListener('submit', function(event) {
    let isValid = true;

    const title = this.querySelector('input[name="title"]');
    const quality = this.querySelector('select[name="quality"]');
    const date = this.querySelector('input[name="publishingDate"]');
    const video = this.querySelector('input[name="video"]');
    const thumbnail = this.querySelector('input[name="thumbnail"]');

    function validateField(field, condition, feedbackTarget = null) {
      const target = feedbackTarget || field;
      if (condition) {
        target.classList.add('is-invalid');
        isValid = false;
      } else {
        target.classList.remove('is-invalid');
      }
    }

    validateField(title, title.value.trim() === "");
    validateField(quality, quality.value === "");
    validateField(date, date.value === "");

    validateField(video, video.files.length === 0, video.nextElementSibling);
    
    if (!isValid) {
      event.preventDefault();
    }
  });