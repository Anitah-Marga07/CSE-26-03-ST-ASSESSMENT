doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Videx | Videos
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css' rel='stylesheet')
  link(rel='stylesheet' href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css')
  link(href='https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap' rel='stylesheet')
  link(href='/css/vidList.css' rel='stylesheet')
nav.navbar.navbar-light
  .container-fluid.p-0
    a.brand-container(href='#')
      .play-icon
        i.bi.bi-play-fill
      h1.brand-name Videx
    a.btn.btn-add-video(href='/upload') Add Video
.container-fluid.content-wrapper
  h2.section-title Videos
  .divider
  .row
    if videos && videos.length > 0
      each video in videos
        .col-12.col-sm-6.col-md-4.col-lg-3.video-card
          .thumbnail
            img(src="/"+ video.thumbnail alt="Image" class="thumbnail-preview")
          
          .video-info-row
            .video-title
              = video.title
            button.options-btn &vellip;
            
          .video-metadata 
            | #{video.views || 0} views . #{video.uploadDate || 'Recent'}
    else
      .col-12.text-center.py-5
        p.text-muted No videos uploaded yet. Be the first!
script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js')
